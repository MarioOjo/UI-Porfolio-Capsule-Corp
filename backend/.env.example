# CORS Configuration
FRONTEND_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
PORT=5000

# Authentication
JWT_SECRET=replace-with-a-strong-random-string-min-32-chars
ADMIN_EMAILS=admin@example.com

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name

# Email (set either RESEND_API_KEY or SENDGRID_API_KEY)
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_TO=team@example.com
FRONTEND_URL=http://localhost:5173

# Cloudinary (preferred single URL form)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Optional Cloudinary split vars (use instead of CLOUDINARY_URL if needed)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional emergency route secret (recommended if emergency route is enabled)
EMERGENCY_ADMIN_SECRET=replace-with-one-time-secret
